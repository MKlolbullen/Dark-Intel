# --- LLM provider -----------------------------------------------------------
# One of: anthropic | gemini | grok
LLM_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MODEL_RELATION=claude-haiku-4-5

# Google Gemini — set LLM_PROVIDER=gemini to activate
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_RELATION=gemini-2.5-flash

# xAI Grok — set LLM_PROVIDER=grok to activate (uses the OpenAI SDK
# pointed at api.x.ai/v1, so no extra dependency needed)
GROK_API_KEY=
GROK_MODEL=grok-4
GROK_MODEL_RELATION=grok-3-mini

# --- Always required --------------------------------------------------------
# OpenAI is used for FAISS embeddings regardless of LLM_PROVIDER
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- App --------------------------------------------------------------------
SECRET_KEY=dev
DB_PATH=intel_graph.db
DEFAULT_CHANNELS=news,reddit,hn,competitor

# --- Optional scraper credentials -------------------------------------------
# Reddit (channel disabled if absent)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=dark-intel/0.2

# LinkedIn (channel disabled if absent)
# Standard developer access token; needs r_organization_social scope to read
# org posts, and admin role on the orgs you want to read. See app/scrapers/linkedin.py.
LINKEDIN_ACCESS_TOKEN=

# X / Twitter (channel disabled if absent)
# Bearer token from a Basic-plan or higher developer account
# (~$200/month). Free tier is write-only as of 2024.
X_BEARER_TOKEN=

# Reviews (Trustpilot scraper, off by default)
# Set to 1 to enable. ToS-restricted; see SCRAPING.md.
ENABLE_REVIEW_SCRAPERS=
